{
  "$schema": "node_modules/wrangler/config-schema.json",
  "name": "kr-ship-write-fe-v2",
  "compatibility_date": "2026-05-06",
  "observability": {
    "enabled": true
  },
  "main": "dist/_worker.js/index.js",
  "compatibility_flags": [
    "global_fetch_strictly_public",
    "nodejs_compat"
  ],
  "assets": {
    "binding": "ASSETS",
    "directory": "dist"
  }
}
