---
interface Props {
	references: string[];
}
const { references } = Astro.props;

function extractDomain(url: string): string {
	try {
		return new URL(url).hostname.replace(/^www\./, '');
	} catch {
		return url;
	}
}
---

{references.length > 0 && (
	<aside class="references" aria-label="References">
		<div class="ref-label">Sources</div>
		<ul class="ref-list">
			{references.map((url) => (
				<li>
					<a href={url} target="_blank" rel="noopener noreferrer">
						{extractDomain(url)}
					</a>
				</li>
			))}
		</ul>
	</aside>
)}

<style>
	.references {
		margin-top: 3.5rem;
		padding-top: 1.25rem;
		border-top: 1px solid rgba(var(--border), 0.6);
	}
	.ref-label {
		font-size: 0.65rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--gray));
		margin-bottom: 0.55rem;
	}
	.ref-list {
		display: flex;
		flex-wrap: wrap;
		gap: 0.4rem;
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.ref-list li a {
		display: inline-block;
		padding: 0.25rem 0.6rem;
		font-size: 0.72rem;
		line-height: 1.35;
		color: rgb(var(--gray));
		background: rgba(var(--border), 0.15);
		border: 1px solid rgba(var(--border), 0.45);
		border-radius: 6px;
		text-decoration: none;
		transition: color 0.12s, border-color 0.12s, background 0.12s;
	}
	.ref-list li a:hover {
		color: rgb(var(--gray-dark));
		border-color: rgba(var(--border), 0.8);
		background: rgba(var(--border), 0.28);
	}
</style>
