---
interface Heading {
	depth: number;
	slug: string;
	text: string;
}
interface Props {
	headings: Heading[];
}
const { headings } = Astro.props;
const filtered = headings.filter((h) => h.depth === 2 || h.depth === 3);
---

{filtered.length > 0 && (
	<nav class="toc" aria-label="Table of contents">
		<div class="toc-title">On this page</div>
		<ul class="toc-list">
			{filtered.map((h) => (
				<li class={`toc-item depth-${h.depth}`}>
					<a href={`#${h.slug}`} data-toc-link={h.slug}>{h.text}</a>
				</li>
			))}
		</ul>
	</nav>
)}

<style>
	.toc {
		display: none;
	}
	@media (min-width: 1280px) {
		.toc {
			display: block;
			position: fixed;
			top: 5.5rem;
			left: max(1rem, calc((100vw - 960px) / 2 - 280px));
			width: 240px;
			max-height: calc(100vh - 7rem);
			overflow-y: auto;
			padding: 1rem 0.85rem;
			background: rgba(var(--surface), 0.72);
			backdrop-filter: blur(12px);
			-webkit-backdrop-filter: blur(12px);
			border: 1px solid rgba(var(--border), 0.5);
			border-radius: 12px;
			z-index: 10;
			scrollbar-width: thin;
			scrollbar-color: rgba(var(--gray), 0.25) transparent;
		}
	}
	.toc-title {
		font-size: 0.7rem;
		font-weight: 700;
		text-transform: uppercase;
		letter-spacing: 0.08em;
		color: rgb(var(--gray));
		margin-bottom: 0.65rem;
		padding-left: 0.15rem;
	}
	.toc-list {
		list-style: none;
		margin: 0;
		padding: 0;
	}
	.toc-item {
		margin: 0;
	}
	.toc-item a {
		display: block;
		padding: 0.3rem 0.4rem;
		font-size: 0.78rem;
		line-height: 1.4;
		color: rgb(var(--gray));
		text-decoration: none;
		border-left: 2px solid transparent;
		border-radius: 0 4px 4px 0;
		transition: color 0.15s, border-color 0.15s, background 0.15s;
	}
	.toc-item a:hover {
		color: rgb(var(--gray-dark));
		background: rgba(var(--border), 0.18);
	}
	.toc-item a.active {
		color: rgb(var(--black));
		border-left-color: var(--accent, rgb(37, 99, 235));
		font-weight: 600;
	}
	.depth-3 a {
		padding-left: 1.1rem;
		font-size: 0.74rem;
	}
</style>

<script>
	function initTOC() {
		const links = document.querySelectorAll<HTMLAnchorElement>('[data-toc-link]');
		if (!links.length) return;
		const slugs = Array.from(links).map((l) => l.dataset.tocLink!);
		const targets = slugs
			.map((s) => document.getElementById(s))
			.filter(Boolean) as HTMLElement[];
		if (!targets.length) return;

		let active = '';
		const observer = new IntersectionObserver(
			(entries) => {
				for (const entry of entries) {
					if (entry.isIntersecting) {
						active = entry.target.id;
						break;
					}
				}
				links.forEach((link) => {
					link.classList.toggle('active', link.dataset.tocLink === active);
				});
			},
			{ rootMargin: '-80px 0px -65% 0px', threshold: 0 },
		);
		targets.forEach((t) => observer.observe(t));

		links.forEach((link) => {
			link.addEventListener('click', (e) => {
				e.preventDefault();
				const target = document.getElementById(link.dataset.tocLink!);
				target?.scrollIntoView({ behavior: 'smooth', block: 'start' });
				history.replaceState(null, '', `#${link.dataset.tocLink}`);
			});
		});
	}
	document.addEventListener('astro:page-load', initTOC);
	if (document.readyState !== 'loading') initTOC();
</script>
